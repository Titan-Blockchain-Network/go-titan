# Titan Explorer — copy to .env.local (dev) or Vercel env vars

# Server-side node API (health, P-chain proxy, validators)
TITAN_BOOTSTRAP_URL=https://rpc.titan-network.xyz

# Or host + scheme (alternative to TITAN_BOOTSTRAP_URL):
# TITAN_NETWORK_HOST=rpc.titan-network.xyz
# TITAN_NETWORK_SCHEME=https

TITAN_NETWORK_NAME=Titan
TITAN_CHAIN_ID=888
TITAN_CHAIN_ID_HEX=0x378

# Public C-chain RPC (MetaMask + wallet UI)
NEXT_PUBLIC_TITAN_RPC_URL=https://rpc.titan-network.xyz/ext/bc/C/rpc

# Local dev against a node on the same machine:
# TITAN_BOOTSTRAP_URL=http://127.0.0.1:9650
# NEXT_PUBLIC_TITAN_RPC_URL=http://127.0.0.1:9650/ext/bc/C/rpc
# TITAN_CHAIN_ID=888

# Only if using a self-signed HTTPS cert on the node:
# TITAN_TLS_INSECURE_SKIP_VERIFY=1

# Ecosystem Launchpad — live apps & on-chain monitors
# Escrow contract deployed on C-Chain (server-side read; also accepts NEXT_PUBLIC_ prefix)
# TITAN_CHESS_ESCROW_ADDRESS=0xYourDeployedEscrowAddress

# Public URL for Titan Chess (opens from Launchpad app card)
NEXT_PUBLIC_TITAN_CHESS_URL=https://chess.titan-network.xyz

# Optional: docs / monorepo link on builder quick-start
# TITAN_DOCS_REPO_URL=https://github.com/Titan-Blockchain-Network/go-titan